# Server Configuration
NODE_ENV=development
PORT=3001

# Client URL (for CORS)
CLIENT_URL=http://localhost:5173

# Base URL (for tracking links)
BASE_URL=http://localhost:3001

# JWT Configuration (REQUIRED - generate a secure random string)
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-secure-jwt-secret-change-this-in-production

# Database Configuration
# DATABASE_TYPE can be 'sqlite' or 'postgres'
DATABASE_TYPE=sqlite

# SQLite Configuration (used when DATABASE_TYPE=sqlite)
SQLITE_PATH=./data/affiliate.db

# PostgreSQL Configuration (used when DATABASE_TYPE=postgres)
DATABASE_URL=postgres://user:password@localhost:5432/affiliate
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=affiliate
POSTGRES_PASSWORD=your-secure-password
POSTGRES_DB=affiliate

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX_REQUESTS=5

# Security
CSRF_SECRET=your-csrf-secret-change-this-in-production
COOKIE_SECURE=false

# Backup Configuration
BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=30

# Admin Account (PRODUCTION ONLY)
# Set these to create an admin account in production
# In development, demo accounts are created automatically
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=your-secure-admin-password
